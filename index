<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Activ Yuva — What's Your Health Type?</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<style>
  :root {
    --teal:#00C896;--teal-dark:#009B73;--navy:#0A1628;
    --navy-card:#122035;--navy-border:#1E3A5F;
    --white:#FFFFFF;--muted:#7A9BB5;--amber:#FFB830;
    --purple:#9B6DFF;--coral:#FF6B6B;
    --card-shadow:0 4px 40px rgba(0,0,0,.3);
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  body{background:var(--navy);color:var(--white);font-family:'DM Sans',sans-serif;min-height:100vh;overflow-x:hidden;}
  body::before{content:'';position:fixed;inset:0;
    background:radial-gradient(ellipse 60% 50% at 80% 20%,rgba(0,200,150,.08) 0%,transparent 70%),
    radial-gradient(ellipse 50% 40% at 20% 80%,rgba(155,109,255,.06) 0%,transparent 70%);
    pointer-events:none;z-index:0;}
  body::after{content:'';position:fixed;inset:0;
    background-image:linear-gradient(rgba(0,200,150,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(0,200,150,.03) 1px,transparent 1px);
    background-size:60px 60px;pointer-events:none;z-index:0;}
  .wrap{position:relative;z-index:1;max-width:680px;margin:0 auto;padding:32px 20px 80px;}

  /* HEADER */
  .hdr{text-align:center;margin-bottom:40px;animation:fadeDown .6s ease both;}
  .brand-pill{display:inline-flex;align-items:center;gap:8px;background:rgba(0,200,150,.1);border:1px solid rgba(0,200,150,.25);border-radius:100px;padding:6px 16px 6px 10px;font-size:12px;font-weight:500;color:var(--teal);letter-spacing:.08em;text-transform:uppercase;margin-bottom:20px;}
  .brand-pill .dot{width:6px;height:6px;background:var(--teal);border-radius:50%;animation:pulseD 2s ease infinite;}
  .hdr h1{font-family:'Syne',sans-serif;font-size:clamp(28px,5vw,40px);font-weight:800;line-height:1.1;letter-spacing:-.02em;margin-bottom:14px;}
  .hdr h1 em{font-style:normal;background:linear-gradient(135deg,var(--teal) 0%,#00E5B3 60%,#7EFFD8 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
  .hdr p{color:var(--muted);font-size:15px;line-height:1.6;max-width:440px;margin:0 auto;}

  /* PROGRESS */
  .prog-wrap{margin-bottom:32px;animation:fadeDown .6s .1s ease both;}
  .prog-meta{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;}
  .prog-lbl{font-family:'Syne',sans-serif;font-size:13px;font-weight:600;color:var(--muted);letter-spacing:.06em;text-transform:uppercase;}
  .xp-pill{display:flex;align-items:center;gap:6px;font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:var(--amber);}
  .xp-pill svg{width:14px;height:14px;}
  .prog-track{height:4px;background:rgba(255,255,255,.06);border-radius:100px;overflow:visible;position:relative;}
  .prog-fill{height:100%;background:linear-gradient(90deg,var(--teal-dark),var(--teal),#00E5B3);border-radius:100px;transition:width .6s cubic-bezier(.34,1.56,.64,1);position:relative;}
  .prog-fill::after{content:'';position:absolute;right:-4px;top:50%;transform:translateY(-50%);width:10px;height:10px;background:var(--teal);border-radius:50%;box-shadow:0 0 10px var(--teal),0 0 20px rgba(0,200,150,.4);}
  .dots{display:flex;justify-content:space-between;margin-top:10px;padding:0 2px;}
  .dot{width:4px;height:4px;background:rgba(255,255,255,.12);border-radius:50%;transition:all .3s;}
  .dot.done{background:var(--teal);}
  .dot.cur{background:var(--teal);box-shadow:0 0 8px var(--teal);transform:scale(1.4);}

  /* CARD */
  .qcard{background:var(--navy-card);border:1px solid var(--navy-border);border-radius:20px;padding:36px 32px 32px;box-shadow:var(--card-shadow);position:relative;overflow:hidden;display:none;animation:slideIn .45s cubic-bezier(.34,1.2,.64,1) both;}
  @media(max-width:480px){.qcard{padding:28px 20px 24px;}}
  .qcard.on{display:block;}
  .qcard::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--teal),transparent);opacity:.5;}
  .qnum{font-family:'Syne',sans-serif;font-size:11px;font-weight:700;color:var(--teal);letter-spacing:.12em;text-transform:uppercase;margin-bottom:12px;opacity:.7;}
  .qtxt{font-family:'Syne',sans-serif;font-size:clamp(18px,3vw,22px);font-weight:700;line-height:1.3;margin-bottom:8px;letter-spacing:-.01em;}
  .qsub{font-size:13px;color:var(--muted);line-height:1.5;margin-bottom:28px;}

  /* TILES */
  .og{display:grid;gap:10px;}
  .og.c2{grid-template-columns:1fr 1fr;}
  @media(max-width:400px){.og.c2{grid-template-columns:1fr;}}
  .tile{background:rgba(255,255,255,.03);border:1.5px solid var(--navy-border);border-radius:14px;padding:14px 18px;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:12px;text-align:left;}
  .tile:hover{background:rgba(0,200,150,.06);border-color:rgba(0,200,150,.3);transform:translateY(-1px);}
  .tile.sel{background:rgba(0,200,150,.1);border-color:var(--teal);box-shadow:0 0 0 1px var(--teal),0 4px 20px rgba(0,200,150,.15);}
  .tile.sel .chk{background:var(--teal);border-color:var(--teal);}
  .tile.sel .chk::after{opacity:1;transform:translate(-50%,-50%) scale(1);}
  .tile.sel .ticon{filter:none;}
  .ticon{font-size:22px;flex-shrink:0;width:36px;text-align:center;filter:grayscale(.3);transition:filter .2s;}
  .tcnt{flex:1;}
  .tlbl{font-size:14px;font-weight:500;line-height:1.3;color:var(--white);}
  .tdsc{font-size:12px;color:var(--muted);margin-top:2px;line-height:1.4;}
  .chk{width:18px;height:18px;border-radius:50%;border:2px solid rgba(255,255,255,.2);flex-shrink:0;position:relative;transition:all .2s;margin-left:auto;}
  .chk::after{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) scale(0);width:6px;height:6px;background:var(--navy);border-radius:50%;opacity:0;transition:all .2s;}

  /* CHIPS */
  .chips{display:flex;flex-wrap:wrap;gap:8px;}
  .chip{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.04);border:1.5px solid rgba(255,255,255,.1);border-radius:100px;padding:9px 16px;cursor:pointer;transition:all .2s;font-size:13px;font-weight:500;}
  .chip:hover{border-color:rgba(0,200,150,.4);background:rgba(0,200,150,.05);}
  .chip.sel{background:rgba(0,200,150,.12);border-color:var(--teal);color:var(--teal);}
  .ci{font-size:16px;}

  /* SLIDER */
  .sl-wrap{padding:8px 0;}
  .sl{-webkit-appearance:none;appearance:none;width:100%;height:6px;background:rgba(255,255,255,.08);border-radius:100px;outline:none;margin:20px 0 16px;cursor:pointer;}
  .sl::-webkit-slider-thumb{-webkit-appearance:none;width:24px;height:24px;background:var(--teal);border-radius:50%;box-shadow:0 0 12px var(--teal),0 2px 6px rgba(0,0,0,.3);cursor:grab;transition:transform .1s;}
  .sl::-webkit-slider-thumb:active{cursor:grabbing;transform:scale(1.2);}
  .sl-lbls{display:flex;justify-content:space-between;font-size:11px;color:var(--muted);margin-top:-8px;}
  .sl-val{text-align:center;font-family:'Syne',sans-serif;font-size:28px;font-weight:800;color:var(--teal);margin-bottom:4px;}
  .sl-val span{font-size:16px;font-weight:600;opacity:.7;}

  /* BUNDLES */
  .bgrid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
  @media(max-width:440px){.bgrid{grid-template-columns:1fr;}}
  .bcard{background:rgba(255,255,255,.03);border:1.5px solid var(--navy-border);border-radius:16px;padding:18px 16px;cursor:pointer;transition:all .25s;position:relative;overflow:hidden;}
  .bcard:hover{transform:translateY(-2px);border-color:rgba(0,200,150,.3);}
  .bcard.sel{border-color:var(--teal);background:rgba(0,200,150,.08);box-shadow:0 0 0 1px var(--teal),0 8px 30px rgba(0,200,150,.12);}
  .bbadge{display:inline-block;font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:3px 8px;border-radius:100px;margin-bottom:10px;}
  .bname{font-family:'Syne',sans-serif;font-size:15px;font-weight:700;margin-bottom:8px;}
  .bfeat{list-style:none;margin-bottom:14px;}
  .bfeat li{font-size:12px;color:var(--muted);padding:2px 0;display:flex;align-items:center;gap:6px;}
  .bfeat li::before{content:'✓';color:var(--teal);font-size:11px;font-weight:700;}
  .bprice{font-family:'Syne',sans-serif;font-size:20px;font-weight:800;}
  .bprice span{font-size:12px;font-weight:400;color:var(--muted);}
  .bcheck{position:absolute;top:12px;right:12px;width:22px;height:22px;background:var(--teal);border-radius:50%;display:flex;align-items:center;justify-content:center;opacity:0;transform:scale(0);transition:all .2s cubic-bezier(.34,1.56,.64,1);}
  .bcard.sel .bcheck{opacity:1;transform:scale(1);}

  /* NEXT BTN */
  .btn-n{display:flex;align-items:center;justify-content:center;gap:10px;width:100%;margin-top:28px;padding:16px 28px;background:linear-gradient(135deg,var(--teal-dark),var(--teal));border:none;border-radius:14px;color:var(--navy);font-family:'Syne',sans-serif;font-size:15px;font-weight:700;letter-spacing:.03em;cursor:pointer;transition:all .25s;box-shadow:0 4px 20px rgba(0,200,150,.25);}
  .btn-n:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(0,200,150,.35);}
  .btn-n:active{transform:translateY(0);}
  .btn-n:disabled{opacity:.35;cursor:not-allowed;transform:none;box-shadow:none;}
  .btn-n svg{width:16px;height:16px;transition:transform .2s;}
  .btn-n:hover:not(:disabled) svg{transform:translateX(3px);}

  /* XP POP */
  .xpop{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:var(--amber);color:var(--navy);font-family:'Syne',sans-serif;font-size:20px;font-weight:800;padding:10px 24px;border-radius:100px;pointer-events:none;z-index:100;opacity:0;}
  .xpop.go{animation:xpPop .8s cubic-bezier(.34,1.56,.64,1) both;}

  /* INSIGHT */
  .insight{background:rgba(155,109,255,.08);border:1px solid rgba(155,109,255,.2);border-radius:12px;padding:14px 16px;margin-top:20px;font-size:12.5px;color:rgba(255,255,255,.7);line-height:1.5;display:none;}
  .insight.on{display:block;animation:fadeIn .4s ease;}
  .insight strong{color:#B99DFF;}

  /* NAV ROW */
  .nav-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;animation:fadeDown .6s .15s ease both;}
  .btn-bk{display:flex;align-items:center;gap:6px;background:none;border:none;color:var(--muted);font-family:'DM Sans',sans-serif;font-size:13px;cursor:pointer;padding:4px 0;transition:color .2s;}
  .btn-bk:hover{color:var(--white);}
  .btn-bk:disabled{opacity:.3;cursor:not-allowed;}
  .time-est{font-size:12px;color:var(--muted);opacity:.6;}

  /* ── RESULT ────────────────────────────────────────────── */
  #result{display:none;animation:fadeIn .6s ease both;}
  #result.on{display:block;}

  .r-hero{background:var(--navy-card);border:1px solid var(--navy-border);border-radius:24px;padding:40px 32px 36px;text-align:center;margin-bottom:16px;position:relative;overflow:hidden;box-shadow:var(--card-shadow);}
  .r-hero::before{content:'';position:absolute;top:-60px;left:50%;transform:translateX(-50%);width:220px;height:220px;background:radial-gradient(circle,rgba(0,200,150,.15) 0%,transparent 70%);pointer-events:none;}
  .r-emoji{font-size:64px;margin-bottom:16px;display:block;animation:bounceIn .6s cubic-bezier(.34,1.56,.64,1) both;}
  .r-type{font-family:'Syne',sans-serif;font-size:11px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--teal);margin-bottom:8px;}
  .r-title{font-family:'Syne',sans-serif;font-size:clamp(24px,5vw,34px);font-weight:800;letter-spacing:-.02em;line-height:1.15;margin-bottom:20px;}
  .r-desc{font-size:13.5px;color:rgba(255,255,255,.72);line-height:1.75;text-align:left;margin-bottom:24px;}
  .xp-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(255,184,48,.1);border:1px solid rgba(255,184,48,.25);border-radius:100px;padding:8px 20px;font-family:'Syne',sans-serif;font-size:15px;font-weight:700;color:var(--amber);margin-bottom:28px;}
  .stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;}
  .stat{background:rgba(255,255,255,.04);border-radius:12px;padding:14px 10px;text-align:center;}
  .sv{font-family:'Syne',sans-serif;font-size:20px;font-weight:800;color:var(--teal);margin-bottom:4px;}
  .sl2{font-size:11px;color:var(--muted);line-height:1.3;}

  /* ABHI FIT */
  .fit-box{background:rgba(0,200,150,.04);border:1px solid rgba(0,200,150,.15);border-radius:16px;padding:22px 24px;margin-bottom:14px;}
  .fit-lbl{font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--teal);margin-bottom:10px;opacity:.8;}
  .fit-txt{font-size:13.5px;color:rgba(255,255,255,.72);line-height:1.7;margin-bottom:14px;}
  .tags{display:flex;flex-wrap:wrap;gap:8px;}
  .tag{background:rgba(0,200,150,.1);border:1px solid rgba(0,200,150,.2);border-radius:100px;padding:5px 12px;font-size:12px;color:var(--teal);font-weight:500;}

  /* PLAN */
  .plan-box{background:var(--navy-card);border:1px solid var(--navy-border);border-radius:20px;padding:26px 26px;margin-bottom:16px;box-shadow:var(--card-shadow);}
  .plan-lbl{font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--teal);margin-bottom:12px;opacity:.8;}
  .plan-name{font-family:'Syne',sans-serif;font-size:18px;font-weight:700;margin-bottom:8px;}
  .plan-txt{font-size:13.5px;color:var(--muted);line-height:1.65;margin-bottom:14px;}

  .cta{display:block;width:100%;padding:17px;background:linear-gradient(135deg,var(--teal-dark),var(--teal));border:none;border-radius:14px;color:var(--navy);font-family:'Syne',sans-serif;font-size:15px;font-weight:700;cursor:pointer;text-decoration:none;text-align:center;transition:all .25s;box-shadow:0 4px 20px rgba(0,200,150,.25);margin-top:20px;}
  .cta:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(0,200,150,.35);}

  .save-ind{display:none;align-items:center;gap:8px;justify-content:center;padding:10px;font-size:12px;color:var(--muted);margin-top:10px;}
  .save-ind.on{display:flex;animation:fadeIn .3s ease;}
  .sdot{width:6px;height:6px;background:var(--teal);border-radius:50%;animation:pulseD 1s ease infinite;}

  /* KEYFRAMES */
  @keyframes fadeDown{from{opacity:0;transform:translateY(-16px)}to{opacity:1;transform:translateY(0)}}
  @keyframes fadeIn{from{opacity:0}to{opacity:1}}
  @keyframes slideIn{from{opacity:0;transform:translateX(30px) scale(.97)}to{opacity:1;transform:translateX(0) scale(1)}}
  @keyframes slideOut{from{opacity:1;transform:translateX(0) scale(1)}to{opacity:0;transform:translateX(-30px) scale(.97)}}
  @keyframes xpPop{0%{opacity:0;transform:translate(-50%,-50%) scale(.5)}40%{opacity:1;transform:translate(-50%,-50%) scale(1.15)}70%{transform:translate(-50%,-80%) scale(1);opacity:1}100%{transform:translate(-50%,-120%) scale(.9);opacity:0}}
  @keyframes bounceIn{0%{transform:scale(.3);opacity:0}60%{transform:scale(1.15)}80%{transform:scale(.95)}100%{transform:scale(1);opacity:1}}
  @keyframes pulseD{0%,100%{opacity:1}50%{opacity:.4}}
</style>
</head>
<body>
<div class="wrap">

  <div class="hdr">
    <div class="brand-pill"><span class="dot"></span>ABHI × Activ Yuva</div>
    <h1>What's Your <em>Health Type?</em></h1>
    <p>10 questions. 3 minutes. Find out which of the 10 Activ Yuva personas you are — and what cover actually fits your life right now.</p>
  </div>

  <div class="prog-wrap">
    <div class="prog-meta">
      <span class="prog-lbl" id="step-lbl">Question 1 of 10</span>
      <div class="xp-pill">
        <svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 1l1.8 3.6L14 5.3l-3 2.9.7 4.1L8 10.4l-3.7 1.9.7-4.1-3-2.9 4.2-.7z"/></svg>
        <span id="xp-ctr">0 XP</span>
      </div>
    </div>
    <div class="prog-track"><div class="prog-fill" id="prog-fill" style="width:10%"></div></div>
    <div class="dots" id="dots"></div>
  </div>

  <div class="nav-row">
    <button class="btn-bk" id="btn-bk" disabled onclick="goBack()">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>Back
    </button>
    <span class="time-est">~3 min</span>
  </div>

  <!-- ════════════ Q1 — CONSISTENCY / IDENTITY ════════════ -->
  <div class="qcard on" id="q1">
    <div class="qnum">01 — Who You Are With Your Health</div>
    <div class="qtxt">Which of these most honestly describes how you show up for your health?</div>
    <div class="qsub">Think about the last 3 months — actual pattern, not aspirational self.</div>
    <div class="og">
      <div class="tile" onclick="T(this,'q1','consistent_identity')">
        <div class="ticon">🏋️</div>
        <div class="tcnt"><div class="tlbl">I show up consistently — fitness is part of who I am</div><div class="tdsc">The gym, studio, or trail is in my weekly schedule without negotiation</div></div>
        <div class="chk"></div>
      </div>
      <div class="tile" onclick="T(this,'q1','wellness_aesthetic')">
        <div class="ticon">🧘</div>
        <div class="tcnt"><div class="tlbl">Wellness is part of my lifestyle and aesthetic</div><div class="tdsc">Pilates, skincare, clean eating, matcha — it's a whole way of living</div></div>
        <div class="chk"></div>
      </div>
      <div class="tile" onclick="T(this,'q1','on_off')">
        <div class="ticon">🔄</div>
        <div class="tcnt"><div class="tlbl">I'm on and off — the intention is always there</div><div class="tdsc">Good stretches, then life happens. The Monday resets are real</div></div>
        <div class="chk"></div>
      </div>
      <div class="tile" onclick="T(this,'q1','social_driven')">
        <div class="ticon">👥</div>
        <div class="tcnt"><div class="tlbl">My health habits follow my social circle</div><div class="tdsc">When friends are doing a challenge or joining a gym, I'm in</div></div>
        <div class="chk"></div>
      </div>
      <div class="tile" onclick="T(this,'q1','data_tracker')">
        <div class="ticon">📊</div>
        <div class="tcnt"><div class="tlbl">I track everything — steps, sleep, calories, health scores</div><div class="tdsc">My apps know more about my body than my doctor does</div></div>
        <div class="chk"></div>
      </div>
      <div class="tile" onclick="T(this,'q1','reactive_employer')">
        <div class="ticon">💼</div>
        <div class="tcnt"><div class="tlbl">I engage with health reactively — check-ups, when something feels off</div><div class="tdsc">My company handles most of it. I manage the rest when I have to</div></div>
        <div class="chk"></div>
      </div>
    </div>
    <button class="btn-n" id="n1" disabled onclick="nxt(1,2,10)">Continue <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg></button>
  </div>

  <!-- ════════════ Q2 — MOTIVATION DRIVER ════════════ -->
  <div class="qcard" id="q2">
    <div class="qnum">02 — What's Driving You Right Now</div>
    <div class="qtxt">What's the real reason your health is on your mind?</div>
    <div class="qsub">The honest answer, not the flattering one.</div>
    <div class="og">
      <div class="tile" onclick="T(this,'q2','performance_goals')">
        <div class="ticon">⚡</div>
        <div class="tcnt"><div class="tlbl">Fitness and performance — I have specific goals I'm working towards</div><div class="tdsc">PRs, body composition, athletic output</div></div>
        <div class="chk"></div>
      </div>
      <div class="tile" onclick="T(this,'q2','managing_concern')">
        <div class="ticon">🩺</div>
        <div class="tcnt"><div class="tlbl">I'm managing something that came up — a condition, a weight shift, a sleep problem</div><div class="tdsc">Something changed and I'm actively trying to address it</div></div>
        <div class="chk"></div>
      </div>
      <div class="tile" onclick="T(this,'q2','recent_wake_up')">
        <div class="ticon">😨</div>
        <div class="tcnt"><div class="tlbl">Something happened recently that woke me up</div><div class="tdsc">A scare, a test result, a hospitalisation near me — the urgency is new</div></div>
        <div class="chk"></div>
      </div>
      <div class="tile" onclick="T(this,'q2','research_prevent')">
        <div class="ticon">🔬</div>
        <div class="tcnt"><div class="tlbl">I've been researching and want to prevent future problems</div><div class="tdsc">I know the risks. I want to stay ahead of them</div></div>
        <div class="chk"></div>
      </div>
      <div class="tile" onclick="T(this,'q2','work_pressure')">
        <div class="ticon">🧠</div>
