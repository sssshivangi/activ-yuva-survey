// ── RESULT ────────────────────────────────────────────
function showResult(){
  if(!S.age||!S.work) return;
  S.xp+=10;
  const persona=classify(); S.persona=persona;

  for(let i=1;i<=TQ;i++){
    const q=document.getElementById('q'+i);
    if(q){q.classList.remove('on');q.style.display='none';}
  }
  document.querySelector('.nav-row').style.display='none';
  document.getElementById('prog-fill').style.width='100%';
  document.getElementById('step-lbl').textContent='Profile complete 🎉';
  document.getElementById('xp-ctr').textContent=S.xp+' XP';
  document.querySelectorAll('.dot').forEach(d=>d.className='dot done');

  render(persona);
  const el=document.getElementById('result');
  el.classList.add('on');
  el.scrollIntoView({behavior:'smooth',block:'start'});
  pop('🎉 Type unlocked!');
  send();
}

function render(key){
  const p=PERSONAS[key]||PERSONAS.lifestyle_improver;
  const annual=S.q4*12, gap=Math.round(annual*.55);
  const fk=n=>n>=10000?'₹'+(n/1000).toFixed(0)+'k':'₹'+n;
  document.getElementById('r-emoji').textContent=p.emoji;
  document.getElementById('r-title').textContent=p.title;
  document.getElementById('r-desc').textContent=p.desc;
  document.getElementById('r-xp').textContent=S.xp+' XP earned';
  document.getElementById('r-spend').textContent=fk(annual);
  document.getElementById('r-gap').textContent=fk(gap);
  document.getElementById('r-cover').textContent=p.cover;
  document.getElementById('r-fit').textContent=p.fit;
  document.getElementById('r-fit-tags').innerHTML=p.fit_tags.map(t=>`<span class="tag">${t}</span>`).join('');
  document.getElementById('r-plan-name').textContent=p.plan;
  document.getElementById('r-plan-txt').textContent=p.plan_txt;
  document.getElementById('r-plan-tags').innerHTML=p.plan_tags.map(t=>`<span class="tag">${t}</span>`).join('');
}

// ── SEND TO SHEET ─────────────────────────────────────
function send(){
  if(!SHEET_URL||SHEET_URL==='https://script.google.com/macros/s/AKfycbwyskS1P-CJw9V2xiA6TVVCSDhoP541z2CNPqj0PKheNVh3eF2A2x0PjL5JuDLPVL0/exec'){
    console.log('Sheet URL not set. Response data:',JSON.stringify(S,null,2));
    return;
  }
  const ind=document.getElementById('save-ind');
  ind.classList.add('on');
  fetch(SHEET_URL,{method:'POST',mode:'no-cors',headers:{'Content-Type':'application/json'},body:JSON.stringify(S)})
  .finally(()=>{ ind.innerHTML='<span style="color:var(--teal)">✓</span><span>Saved. Thank you!</span>'; });
}
