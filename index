  document.getElementById('ins4').innerHTML=`<strong>💡 At ₹${n.toLocaleString('en-IN')}/month</strong> you're spending ${fk(annual)}/year on health. With OPD cover, up to ${fk(gap)} of that could be offset — spend you're currently absorbing entirely yourself.`;
