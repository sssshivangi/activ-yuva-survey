}
function goBack(){
  const q=S.cq; if(q<=1) return;
  document.getElementById('q'+q).classList.remove('on');
  const pc=document.getElementById('q'+(q-1));
  pc.style.animation='slideIn .35s ease both';
  pc.classList.add('on'); S.cq=q-1; updProg(q-1);
}
function updProg(q){
  document.getElementById('prog-fill').style.width=Math.round((q/TQ)*100)+'%';
  document.getElementById('step-lbl').textContent=`Question ${q} of ${TQ}`;
  for(let i=1;i<=TQ;i++){
    const d=document.getElementById('d'+i);
    if(d) d.className='dot'+(i<q?' done':i===q?' cur':'');
  }
  document.getElementById('btn-bk').disabled=q<=1;
}
function pop(txt){
  const el=document.getElementById('xpop');
  el.textContent=txt; el.classList.remove('go');
  void el.offsetWidth; el.classList.add('go');
}

