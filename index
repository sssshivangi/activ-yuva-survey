function chip(el,k,v){
  if(v==='nothing'){
    document.querySelectorAll('#ch'+k.replace('q','')+' .chip').forEach(c=>c.classList.remove('sel'));
    S[k]=['nothing']; el.classList.add('sel');
  } else {
    document.querySelectorAll('#ch'+k.replace('q','')+' .chip').forEach(c=>{
      if(c.onclick&&c.onclick.toString().includes("'nothing'")) c.classList.remove('sel');
    });
    S[k]=S[k].filter(x=>x!=='nothing');
    if(el.classList.contains('sel')){el.classList.remove('sel');S[k]=S[k].filter(x=>x!==v);}
    else{el.classList.add('sel');S[k].push(v);}
  }
  const nb=document.getElementById('n'+k.replace('q',''));
  if(nb) nb.disabled=S[k].length===0;
  if(k==='q3'&&S.q3.length>=2) document.getElementById('ins3').classList.add('on');
}
