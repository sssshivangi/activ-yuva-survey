// PERSONA CLASSIFICATION — weighted signal engine
// Maps Q1–Q10 responses to 10 WS1 personas
// ══════════════════════════════════════════════════════
function classify(){
  const sc={
    health_surrogate:0, lifestyle_improver:0, corporate_professional:0,
    digital_health_native:0, oscillator:0, social_fitness:0,
    anxious_researcher:0, recently_jolted:0, wellness_aesthete:0, newly_independent:0
  };

  // Q1 — strongest identity signal (weight: 4–5)
  Object.entries(({
    consistent_identity: {health_surrogate:5},
    wellness_aesthetic:  {wellness_aesthete:5},
    on_off:              {oscillator:5},
    social_driven:       {social_fitness:5},
    data_tracker:        {digital_health_native:5},
    reactive_employer:   {corporate_professional:4}
  }[S.q1])||{}).forEach(([k,v])=>sc[k]+=v);

  // Q2 — motivation driver (weight: 4–5)
  Object.entries(({
    performance_goals: {health_surrogate:4},
    managing_concern:  {lifestyle_improver:5},
    recent_wake_up:    {recently_jolted:5},
    research_prevent:  {anxious_researcher:5},
    work_pressure:     {corporate_professional:4, lifestyle_improver:1},
    figuring_out:      {newly_independent:5}
  }[S.q2])||{}).forEach(([k,v])=>sc[k]+=v);

  // Q3 — spend signals (weight: 1–3)
  const q3m = {
    gym:{health_surrogate:3,social_fitness:1},
    pilates_yoga:{wellness_aesthete:3,health_surrogate:1},
    running_gear:{health_surrogate:3},
    doctor:{lifestyle_improver:2,anxious_researcher:1},
    diagnostics:{lifestyle_improver:2,anxious_researcher:2},
    therapy:{corporate_professional:2,lifestyle_improver:1},
    nutritionist:{lifestyle_improver:2,wellness_aesthete:1},
    supplements:{health_surrogate:1,wellness_aesthete:2,anxious_researcher:1},
    wearable:{digital_health_native:3},
    health_app:{digital_health_native:2},
    nothing:{newly_independent:2,oscillator:1}
  };
  S.q3.forEach(v=>{ const m=q3m[v]||{}; Object.entries(m).forEach(([k,val])=>sc[k]+=val); });

  // Q5 — insurance awareness (weight: 2–4)
  Object.entries(({
    comprehensive:   {health_surrogate:1,digital_health_native:1},
    hospital_only:   {lifestyle_improver:1,corporate_professional:1},
    employer_unsure: {corporate_professional:4},
    no_insurance:    {newly_independent:3,oscillator:1}
  }[S.q5])||{}).forEach(([k,v])=>sc[k]+=v);

  // Q8 — feature signals (weight: 1–2)
  const q8m = {
    cashback:{health_surrogate:2},
    opd_cover:{lifestyle_improver:2,wellness_aesthete:1},
    mental_health:{corporate_professional:2,lifestyle_improver:1},
    diagnostics:{anxious_researcher:3},
    maternity:{wellness_aesthete:3},
    income:{corporate_professional:3},
    app_easy:{digital_health_native:2},
    transparent:{anxious_researcher:2,lifestyle_improver:1},
    partner:{wellness_aesthete:2},
    pause:{health_surrogate:1,corporate_professional:1}
  };
  S.q8.forEach(v=>{ const m=q8m[v]||{}; Object.entries(m).forEach(([k,val])=>sc[k]+=val); });

  // Q9 — discovery behaviour (weight: 3)
  Object.entries(({
    deep_research:     {anxious_researcher:3},
    friend_rec:        {social_fitness:3},
    creator_discovery: {wellness_aesthete:2,health_surrogate:1},
    data_prompted:     {digital_health_native:3},
    employer_hr:       {corporate_professional:3},
    impulse_reset:     {oscillator:3}
  }[S.q9])||{}).forEach(([k,v])=>sc[k]+=v);

  // Demographics (weight: 1–3)
  if(S.age==='18-24'){sc.newly_independent+=3;sc.oscillator+=1;}
  if(S.age==='25-29'){sc.health_surrogate+=1;sc.wellness_aesthete+=1;sc.social_fitness+=1;}
  if(S.age==='30-34'){sc.corporate_professional+=1;sc.lifestyle_improver+=1;sc.anxious_researcher+=1;}
  if(S.age==='35-40'){sc.corporate_professional+=2;sc.lifestyle_improver+=1;}
  if(S.work==='salaried_corp'){sc.corporate_professional+=3;}
  if(S.work==='salaried_startup'){sc.digital_health_native+=1;sc.corporate_professional+=1;}
  if(S.work==='student_other'){sc.newly_independent+=3;}
  if(S.work==='self_employed'){sc.lifestyle_improver+=1;sc.oscillator+=1;}

  // WTP as income signal (weight: 1)
  if(S.q6==='gt1000'){sc.corporate_professional+=1;sc.health_surrogate+=1;}
  if(S.q6==='lt300'){sc.newly_independent+=1;sc.oscillator+=1;}

  // Bundle pick (weight: 1–2)
  if(S.q7==='active'){sc.health_surrogate+=2;sc.digital_health_native+=1;}
  if(S.q7==='premium'){sc.corporate_professional+=2;sc.lifestyle_improver+=1;}
  if(S.q7==='essential'){sc.newly_independent+=1;sc.oscillator+=1;}
  if(S.q7==='opd'){sc.lifestyle_improver+=2;sc.anxious_researcher+=1;}

  return Object.entries(sc).sort((a,b)=>b[1]-a[1])[0][0];
}

